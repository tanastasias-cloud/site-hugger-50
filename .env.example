# Path to the local SQLite database file (created automatically on first write).
# Defaults to "data/app.db" relative to the project root if not set.
DB_PATH=

# --- Gmail API (Google Workspace) ---
# Used to send a notification email to info@getgrow.academy whenever a new
# contact request comes in. See src/lib/email.server.ts for setup instructions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=info@getgrow.academy
CONTACT_NOTIFICATION_EMAIL=info@getgrow.academy
